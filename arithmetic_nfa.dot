digraph "Arithmetic expressions" {
  rankdir=LR;
  compound=true;
  graph [fontname="Helvetica"];
  node [shape=circle, fontsize=10, fontname="Helvetica"];
  edge [fontsize=9, fontname="Helvetica"];
  subgraph "cluster_number" {
    label="number";
    style=rounded;
